      </column>
      <column caption='Shutdown Status' datatype='string' name='[Calculation_1148211948240899]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [percentage_laid_off] = 1 THEN &quot;Shutdown&quot;&#13;&#10;ELSE &quot;Not Shutdown&quot;&#13;&#10;END' />
